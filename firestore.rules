rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required, email format)
    //   - role: string (required, enum: ['user', 'admin', 'co-admin'])
    //   - trialExpiry: timestamp (required)
    //   - subscriptionExpiry: timestamp (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: licenseKeys
    // Document ID: {keyId}
    // Fields:
    //   - key: string (required, 16 chars)
    //   - durationMonths: int (required, enum: [1, 3, 6, 12])
    //   - isUsed: bool (required)
    //   - usedBy: string (optional, uid)
    //   - createdAt: timestamp (required)
    //
    // Collection: templateAssets
    // Document ID: {assetId}
    // Fields:
    //   - name: string (required)
    //   - url: string (required, URL format)
    //   - category: string (required, enum: ['16:9', '9:16', 'banner'])
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email != null && (request.auth.token.email.toLower() == "tsaikurt0921@gmail.com" || request.auth.token.email.toLower() == "kurttsai0921@gmail.com")) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'co-admin'])
        );
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email != null && (request.auth.token.email.toLower() == "tsaikurt0921@gmail.com" || request.auth.token.email.toLower() == "kurttsai0921@gmail.com")) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidUrl(url) {
       return url is string && url.size() > 0 && url.size() < 2000;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'trialExpiry', 'subscriptionExpiry', 'createdAt']) &&
             data.email is string &&
             data.role in ['user', 'admin', 'co-admin'] &&
             data.trialExpiry is timestamp &&
             data.subscriptionExpiry is timestamp &&
             data.createdAt is timestamp;
    }

    function isValidLicenseKey(data) {
      return data.keys().hasAll(['key', 'durationMonths', 'isUsed', 'createdAt']) &&
             data.key is string && data.key.size() == 16 &&
             data.durationMonths in [1, 3, 6, 12] &&
             data.isUsed is bool &&
             data.createdAt is timestamp;
    }

    function isValidSharedDisplay(data) {
      return data.keys().hasAll(['layout', 'zonesData', 'ownerId', 'createdAt']) &&
             data.layout is string &&
             data.zonesData is map &&
             data.ownerId is string &&
             data.createdAt is timestamp;
    }

    function isValidSavedTemplate(data) {
      return data.keys().hasAll(['userId', 'name', 'baseTemplateId', 'zonesConfig', 'type', 'createdAt']) &&
             data.userId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.baseTemplateId is string &&
             data.zonesConfig is map &&
             data.type in ['landscape', 'portrait'] &&
             data.createdAt is timestamp;
    }

    function isValidTemplateAsset(data) {
      return data.keys().hasAll(['name', 'url', 'category', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.url is string && data.url.size() < 1000 && isValidUrl(data.url) &&
             data.category in ['16:9', '9:16', 'banner'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /licenseKeys/{keyId} {
      allow read: if isAdmin() || (isAuthenticated() && !resource.data.isUsed); // Users can check if a key exists and is not used
      allow create: if isAdmin() && isValidLicenseKey(request.resource.data);
      allow update: if (isAdmin() && isValidLicenseKey(request.resource.data)) || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedBy', 'usedByEmail']) &&
        request.resource.data.isUsed == true &&
        resource.data.isUsed == false &&
        request.resource.data.usedBy == request.auth.uid
      );
      allow delete: if isSuperAdmin();
    }

    match /sharedDisplays/{displayId} {
      allow read: if true; // Public access
      allow create: if isAuthenticated() && isValidSharedDisplay(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid && isValidSharedDisplay(request.resource.data) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /savedTemplates/{templateId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidSavedTemplate(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidSavedTemplate(request.resource.data) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /pricingPlans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /playbackProjects/{projectId} {
      allow read: if true; // Public for playback
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /templateAssets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidTemplateAsset(request.resource.data);
    }
  }
}
